{
    "name": "alleyinteractive/wp-multisite-flush-rewrite",
    "description": "Flush rewrite rules on a WordPress multisite.",
    "type": "wordpress-plugin",
    "keywords": [
        "alleyinteractive",
        "wp-multisite-flush-rewrite"
    ],
    "homepage": "https://github.com/alleyinteractive/wp-multisite-flush-rewrite",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Sean Fisher",
            "email": "sean@alley.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "alleyinteractive/composer-wordpress-autoloader": "^1.0",
        "mantle-framework/http-client": "^1.8",
        "mantle-framework/support": "^1.8"
    },
    "require-dev": {
        "alleyinteractive/alley-coding-standards": "^2.0",
        "mantle-framework/testkit": "^1.4",
        "php-stubs/wp-cli-stubs": "^2.12",
        "rector/rector": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "alleyinteractive/composer-wordpress-autoloader": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "autoload-dev": {
        "psr-4": {
            "Alley\\WP\\Multisite_Flush_Rewrite\\Tests\\": "tests"
        }
    },
    "extra": {
        "wordpress-autoloader": {
            "autoload": {
                "Alley\\WP\\Multisite_Flush_Rewrite\\": "src"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "phpcbf": "phpcbf .",
        "phpcs": "phpcs .",
        "phpstan": "phpstan --memory-limit=512M",
        "lint": [
            "@phpcs",
            "@phpstan",
            "@rector"
        ],
        "lint:fix": [
            "@rector:fix",
            "@phpcbf"
        ],
        "phpunit": "phpunit",
        "rector:fix": "rector process",
        "rector": "rector process --dry-run",
        "release": "npx @alleyinteractive/create-release@latest",
        "serve": "command -v wp-env >/dev/null 2>&1 || npm install -g @wordpress/env && wp-env start",
        "test": [
            "@lint",
            "@phpunit"
        ]
    }
}
